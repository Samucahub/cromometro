PORT=3000
DATABASE_URL="postgresql://semstress:semstress@localhost:5432/semstress"
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="24h"
ADMIN_SETUP_KEY="your-admin-setup-key"

# Google OAuth
